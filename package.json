{
  "name": "scripture-journal",
  "version": "0.1.0",
  "private": true,
  "description": "Web-based journaling tool for annotating preserved scripture and article content.",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"api,vite\" --prefix-colors \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:api": "tsx watch scripts/dev-server.ts",
    "dev:vite": "vite",
    "build": "vite build",
    "build:lambda": "tsx scripts/build-lambda.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --project=chromium-headed",
    "test:e2e:ui": "playwright test --ui",
    "create-user": "tsx --env-file .env.local scripts/create-user.ts",
    "create-user:deployed": "tsx --env-file .env scripts/create-user.ts",
    "ingest-scripture": "tsx --env-file .env.local scripts/ingest-scripture.ts",
    "ingest-scripture:deployed": "tsx --env-file .env scripts/ingest-scripture.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.0.0",
    "@tanstack/react-query": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.0.0",
    "jose": "^5.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "aws-sdk-client-mock": "^4.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
