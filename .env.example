# Copy this file to .env and fill in deployed environment values.
# .env is gitignored — never commit real secrets.
#
# Used by scripts that target the deployed AWS environment, e.g.:
#   npm run create-user:deployed -- --username peter --password "..."
#
# AWS credentials must be active before running:
#   aws sso login
#   export AWS_PROFILE=<your-profile>   # if using a named profile

# ── Required ──────────────────────────────────────────────────────────────────

BUCKET_NAME=scripture-journal-app-818371815071-dev
ENV=dev
CLOUDFRONT_DOMAIN=dn7nx12sz8wyv.cloudfront.net
ADMIN_USERNAME=peter

# JWT secret is stored in SSM in the deployed environment — leave blank.
# JWT_SECRET=

# ── Optional overrides ────────────────────────────────────────────────────────

# AWS_REGION=us-east-1
# AWS_PROFILE=
