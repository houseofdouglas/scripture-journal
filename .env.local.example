# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
#
# AWS credentials are loaded automatically from your SSO session:
#   aws sso login --profile <your-profile>
#   export AWS_PROFILE=<your-profile>   # or set in shell rc

# ── Required ─────────────────────────────────────────────────────────────────

# S3 bucket that holds all app data (created by Terraform or manually)
BUCKET_NAME=scripture-journal-dev-data

# Deployment environment label — also used to build the SSM parameter path
ENV=dev

# CloudFront domain (or localhost for local dev)
CLOUDFRONT_DOMAIN=localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────

# Admin username — this account gets admin privileges in the app
ADMIN_USERNAME=peter

# JWT signing secret.
# Option A (local dev): set this directly — skips the SSM lookup.
# Option B (production / deployed): leave blank and the server reads from
#   SSM at /scripture-journal/<ENV>/jwt-secret
JWT_SECRET=local-dev-secret-change-me

# ── Optional overrides ────────────────────────────────────────────────────────

# Port for the local API server (default: 4000)
# DEV_API_PORT=4000

# AWS region (default: us-east-1)
# AWS_REGION=us-east-1

# AWS profile to use if you have multiple SSO profiles
# AWS_PROFILE=scripture-journal-dev
